{
  "name": "ecotrack",
  "version": "1.0.0",
  "description": "Ecosystem Management & Food Chain Visualization System using HashMap, Queue, and Graph data structures",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "server": "nodemon --watch server --ext js,mjs,cjs,json server/server.js",
    "dev:full": "concurrently -k \"npm run server\" \"wait-on tcp:5000 && npm run dev\""
  },
  "keywords": [
    "ecosystem",
    "food-chain",
    "data-structures",
    "visualization",
    "cytoscape"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "cytoscape": "^3.33.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "graphlib": "^2.1.8",
    "heap-js": "^2.7.1",
    "mongoose": "^9.3.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "vite": "^5.0.0",
    "wait-on": "^9.0.4"
  }
}
